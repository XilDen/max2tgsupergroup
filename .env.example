# Legacy bootstrap (optional): if set together with TG_CHAT_ID, one account is auto-registered on first start
MAX_TOKEN=
MAX_DEVICE_ID=

# Telegram bot token (required)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_ADMIN_ID=123456789

# Optional: legacy auto-bootstrap chat/user id
TG_CHAT_ID=123456789

# Telegram супергруппа (с минусом) – если заполнена, бот будет использовать её с топиками
TG_SUPERGROUP_ID=-1001234567890

# Включить режим форума (топики) – по умолчанию true
FORUM_ENABLED=true

# SQLite path for account bindings
DB_PATH=data/max2tg.sqlite3

# Global timezone for logs, reports, backups and admin-visible event times
APP_TIMEZONE=Europe/Moscow

# Optional: create weekly SQLite backups on disk (disabled by default)
DB_BACKUP_ENABLED=false

# Required: key for encrypting max_token/max_device_id in DB (any long random string)
ENCRYPTION_KEY=change_me_to_a_long_random_secret

# Optional Redis queue backend for high message throughput.
# Default for local/systemd launch.
# Docker Compose overrides this value to `redis://redis:6379/0` automatically.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=max2tg
TG_QUEUE_WORKERS=3
TG_MIN_SEND_INTERVAL_MS=80
TG_QUEUE_MAX_ATTEMPTS=3
TG_QUEUE_JOB_TTL_SEC=300

# Debug mode: подробные логи (true/false)
DEBUG=false

# Разрешить ответы из Telegram в Max (true/false)
REPLY_ENABLED=false
